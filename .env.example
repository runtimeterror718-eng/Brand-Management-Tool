# ============================================================
# OVAL — Application Configuration
# Copy to .env and fill in values.
# Secrets go in secrets/.env.keys (see secrets/.env.keys.example)
# ============================================================

# --- LLM Defaults ---
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Reddit ---
REDDIT_USER_AGENT=brand-tool/1.0

# --- YouTube Pipeline Tuning ---
YOUTUBE_UNOFFICIAL_MAX_RESULTS_PER_KEYWORD=25
YOUTUBE_UNOFFICIAL_PUBLISHED_AFTER_DAYS=30
YOUTUBE_UNOFFICIAL_MAX_COMMENTS_PER_FLAGGED_VIDEO=200

# --- Azure OpenAI Config ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_BATCH_ENABLED=false
AZURE_OPENAI_BATCH_INPUT_DIR=/tmp/azure_openai_batch/input
AZURE_OPENAI_BATCH_OUTPUT_DIR=/tmp/azure_openai_batch/output
AZURE_OPENAI_BATCH_POLL_INTERVAL_SECONDS=15
AZURE_OPENAI_BATCH_POLL_TIMEOUT_SECONDS=300

# --- Whisper Proxy Config ---
WHISPER_PROXY_SUBMIT_URL=https://your-whisper-proxy/submit
WHISPER_PROXY_RESULT_URL=https://your-whisper-proxy/task-result
WHISPER_PROXY_WORKFLOW_NAME=your-workflow-name
WHISPER_PROXY_LANGUAGE=hi
WHISPER_PROXY_POLL_INTERVAL_SECONDS=5
WHISPER_PROXY_POLL_TIMEOUT_SECONDS=300

# --- Alerts Config ---
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_FROM=
EMAIL_RECIPIENTS=user1@example.com,user2@example.com

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Monitored Brands ---
MONITORED_BRANDS=brand1,brand2
