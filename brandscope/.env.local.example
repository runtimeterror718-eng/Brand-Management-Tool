# BrandScope (Next.js) — Environment Variables
# Copy to brandscope/.env.local and fill in real values.

# Supabase (required — dashboard won't load without these)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_KEY=eyJ...

# Supabase service key (for API routes that need admin access)
SUPABASE_SERVICE_KEY=eyJ...

# Google (for SEO/News pages)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# OpenAI (for AI-powered features in dashboard)
OPENAI_API_KEY=sk-proj-...
